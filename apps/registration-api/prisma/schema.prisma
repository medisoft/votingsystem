generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AdminRole {
  SYSTEM_ADMIN
  REGISTRATION_OPERATOR
  AUDITOR
}

enum AdminStatus {
  ACTIVE
  INACTIVE
}

enum ActorType {
  ADMIN
  SYSTEM
  ANONYMOUS
}

enum VotingScopeStatus {
  DRAFT
  REGISTRATION_OPEN
  ACTIVATION_OPEN
  VOTING_ACTIVE
  CLOSED
  ARCHIVED
}

model VotingScope {
  id                   String             @id @default(uuid()) @db.Uuid
  name                 String
  description          String?
  status               VotingScopeStatus  @default(DRAFT)
  startsAt             DateTime
  endsAt               DateTime
  activationStartsAt   DateTime
  activationEndsAt     DateTime
  credentialExpiresAt  DateTime
  votingWeightsEnabled Boolean            @default(false)
  issuerKeyVersion     String
  version              Int                @default(1)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  eligibilities        ScopeEligibility[]

  @@index([status])
  @@index([startsAt, endsAt])
}

enum RegistrationStatus {
  ACTIVE
  INACTIVE
}

model RegistrationRecord {
  id                 String             @id @default(uuid()) @db.Uuid
  /// Stored uppercase; enforced by a database CHECK constraint.
  unitNumber         String             @unique
  ownerName          String
  representativeName String?
  email              String?
  phone              String?
  votingWeight       Decimal            @default(1) @db.Decimal(12, 4)
  eligible           Boolean            @default(true)
  status             RegistrationStatus @default(ACTIVE)
  notes              String?
  version            Int                @default(1)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  deletedAt          DateTime?
  scopeEligibilities ScopeEligibility[]

  @@index([ownerName])
  @@index([email])
  @@index([eligible, status])
}

model ScopeEligibility {
  id                   String             @id @default(uuid()) @db.Uuid
  registrationRecordId String             @db.Uuid
  votingScopeId        String             @db.Uuid
  eligible             Boolean
  votingWeight         Decimal            @db.Decimal(12, 4)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  registrationRecord   RegistrationRecord @relation(fields: [registrationRecordId], references: [id], onDelete: Cascade)
  votingScope          VotingScope        @relation(fields: [votingScopeId], references: [id], onDelete: Cascade)

  @@unique([registrationRecordId, votingScopeId])
  @@index([votingScopeId, eligible])
}

model AdminUser {
  id               String         @id @default(uuid()) @db.Uuid
  email            String         @unique
  passwordHash     String
  role             AdminRole
  status           AdminStatus    @default(ACTIVE)
  failedLoginCount Int            @default(0)
  lockedUntil      DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  sessions         AdminSession[]

  @@index([status])
}

model AdminSession {
  id        String    @id @default(uuid()) @db.Uuid
  tokenHash String    @unique
  adminId   String    @db.Uuid
  admin     AdminUser @relation(fields: [adminId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime  @default(now())
  rotatedAt DateTime?
  revokedAt DateTime?

  @@index([adminId, expiresAt])
}

model AuditEvent {
  id           String    @id @default(uuid()) @db.Uuid
  occurredAt   DateTime  @default(now())
  actorType    ActorType
  actorId      String?   @db.Uuid
  eventType    String
  targetType   String
  targetId     String?
  sourceIp     String?
  metadata     Json
  previousHash String?
  eventHash    String    @unique

  @@index([occurredAt])
  @@index([eventType])
}

model RegistrationImport {
  id           String   @id @default(uuid()) @db.Uuid
  fileHash     String   @unique
  fileName     String
  totalRows    Int
  importedRows Int
  rejectedRows Int
  errors       Json
  createdBy    String   @db.Uuid
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([createdBy])
}
